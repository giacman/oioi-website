extends layout.pug

block title
    title= t('matricaria.title')

block meta_description
    meta(name='description', content=t('matricaria.meta_description'))

block canonical
    link(rel='canonical', href=canonicalBase + localePrefix + 'matricaria.html')

block og_title
    meta(property='og:title', content=t('matricaria.title'))
block og_description
    meta(property='og:description', content=t('matricaria.meta_description'))
block og_image
    meta(property='og:image', content=canonicalBase + 'assets/img/portfolio/matricaria.png')
block og_url
    meta(property='og:url', content=canonicalBase + localePrefix + 'matricaria.html')

block content
    // Masthead
    header.masthead(style='padding-bottom: 3rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.fw-medium.my-0(style='font-size: 1.4rem;') MATRICARIA
                        span.decorative-icon.ms-2 ✴︎🜃
                    p.mt-3= t('matricaria.subtitle')
                    hr.divider

    // Collection Gallery
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.shop-cta-row.justify-content-center
                .col-12.text-center
                    a.shop-collection-link.shop-cta(href='https://shop.oioijewellery.it/collections/matricaria', data-collection='matricaria')= t('matricaria.shop_now')
        +compactGalleryWrapper
            +compactGalleryGrid
                - var shopHref = 'https://shop.oioijewellery.it/collections/matricaria'
                - var shopOpts = { shopHref: shopHref, dataCollection: 'matricaria', eager: true }
                +compactGalleryImage('assets/img/portfolio/matricaria/01-hand-rings.png', 'MATRICARIA - Anelli indossati', shopOpts)
                +compactGalleryImage('assets/img/portfolio/matricaria/02-rings-stems.png', 'MATRICARIA - Anelli su steli', { shopHref: shopHref, dataCollection: 'matricaria' })
                +compactGalleryImage('assets/img/portfolio/matricaria/03-rings-lined.png', 'MATRICARIA - Anelli in fila', { shopHref: shopHref, dataCollection: 'matricaria' })
                +compactGalleryImage('assets/img/portfolio/matricaria/04-lifestyle.png', 'MATRICARIA - Lifestyle', { shopHref: shopHref, dataCollection: 'matricaria' })
                +compactGalleryImage('assets/img/portfolio/matricaria/05-designs.png', 'MATRICARIA - Schizzi di design', { shopHref: shopHref, dataCollection: 'matricaria' })
                +compactGalleryImage('assets/img/portfolio/matricaria/06-rings-quadri.png', 'MATRICARIA - Collezione anelli', { shopHref: shopHref, dataCollection: 'matricaria' })

    // Description and Contact
    section#contact.page-section(style='padding-top: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-start
                .col-lg-6
                    p
                        each p_text, idx in i18n.matricaria.description
                            if idx > 0
                                br
                            = p_text
                        br
                        br
                        each variant, vidx in i18n.matricaria.variants
                            if vidx > 0
                                br
                            = '– ' + variant
                        br
                        br
                        = t('matricaria.gold_note')
                        br
                        br
                        = t('matricaria.production_time')
                .col-lg-6.contact-form-column

                    // Netlify Forms
                    form#contactForm(name='contact-matricaria', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                        // Netlify Forms hidden fields
                        input(type='hidden', name='form-name', value='contact-matricaria')
                        input(type='hidden', name='collection', value='MATRICARIA')
                        // Honeypot field
                        input(type='text', name='bot-field', class='d-none')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name')= t('form.full_name')
                            .invalid-feedback(data-sb-feedback='name:required')
                                = t('form.name_required')

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email')= t('form.email')
                            .invalid-feedback(data-sb-feedback='email:required')
                                = t('form.email_required')
                            .invalid-feedback(data-sb-feedback='email:email')
                                = t('form.email_invalid')

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890'
                            )
                            label(for='phone')= t('form.phone')

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                type='text',
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message')= t('form.message')
                            .invalid-feedback(data-sb-feedback='message:required')
                                = t('form.message_required')

                        // Submit Button
                        .d-grid
                            button#submitButton.btn-reset(type='submit')
                                +svg-entra-in-contatto(t('form.submit_cta'), '140px')
