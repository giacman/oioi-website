extends layout.pug

block title
    title= t('index.title')

block content
    // Masthead
    header.masthead(style='padding-bottom: 3rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    img.mb-4.masthead-logotype(src=basePath + 'assets/img/logos/oioi_logotype_black.svg', alt='OIOI')
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.my-0(style='font-size: 1.4rem;')= t('index.subtitle')
                        span.decorative-icon.ms-2 ✴︎🜃
                    p= t('index.tagline')
                    hr.divider
    // Homepage gallery (3×2, no gutters — Instagram-style)
    #portfolio.homepage-gallery
        .homepage-gallery__grid
            .homepage-gallery__cell
                a(href='matricaria.html')
                    img(src=basePath + 'assets/img/portfolio/matricaria/02-rings-stems.png', alt='', loading='lazy')
            .homepage-gallery__cell
                a(href='matricaria.html')
                    img(src=basePath + 'assets/img/portfolio/homepage/02.jpeg', alt='', loading='lazy')
            .homepage-gallery__cell
                a(href='things.html')
                    img(src=basePath + 'assets/img/portfolio/homepage/03.jpeg', alt='', loading='lazy')
            .homepage-gallery__cell
                a(href='things.html')
                    img(src=basePath + 'assets/img/portfolio/things/thumbnails/pesce_viola.png', alt='', loading='lazy')
            .homepage-gallery__cell
                a(href='things.html')
                    img(src=basePath + 'assets/img/portfolio/homepage/05-they-them-rings.png', alt='', loading='lazy')
            .homepage-gallery__cell
                a(href='opera.html')
                    img(src=basePath + 'assets/img/portfolio/homepage/06.png', alt='', loading='lazy')

    // Contact
    section#contact.page-section(style='padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-8
                    p.mb-3.text-center(style='font-size: 1.1rem;')= t('index.contact_intro')
                    p.font-calligraphy.text-center.mb-3(style='font-size: 2rem; line-height: 1.6;')= t('index.contact_calligraphy')
                .col-lg-5.col-md-8.contact-form-column
                    // Netlify Forms
                    form#contactForm(name='contact', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                            // Netlify Forms hidden fields
                            input(type='hidden', name='form-name', value='contact')
                            // Honeypot field
                            input(type='text', name='bot-field', class='d-none')

                            // Name input
                            .form-floating.mb-3
                                input#name.form-control(
                                    type='text',
                                    name='name',
                                    placeholder='Enter your name...',
                                    required
                                )
                                label(for='name')= t('form.full_name')
                                .invalid-feedback(data-sb-feedback='name:required')
                                    = t('form.name_required')

                            // Email address input
                            .form-floating.mb-3
                                input#email.form-control(
                                    type='email',
                                    name='email',
                                    placeholder='name@example.com',
                                    required
                                )
                                label(for='email')= t('form.email')
                                .invalid-feedback(data-sb-feedback='email:required')
                                    = t('form.email_required')
                                .invalid-feedback(data-sb-feedback='email:email')
                                    = t('form.email_invalid')

                            // Phone number input
                            .form-floating.mb-3
                                input#phone.form-control(
                                    type='tel',
                                    name='phone',
                                    placeholder='(123) 456-7890'
                                )
                                label(for='phone')= t('form.phone')

                            // Message input
                            .form-floating.mb-3
                                textarea#message.form-control(
                                    type='text',
                                    name='message',
                                    placeholder='Enter your message here...',
                                    style='height: 10rem;',
                                    required
                                )
                                label(for='message')= t('form.message')
                                .invalid-feedback(data-sb-feedback='message:required')
                                    = t('form.message_required')

                            // Submit Button
                            .d-grid.mt-4
                                button#submitButton.btn-reset(type='submit')
                                    +svg-entra-in-contatto(t('form.submit_cta'), '140px')
