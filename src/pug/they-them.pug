extends layout.pug

block title
    title= (cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].seoTitle) || t('they_them.title')

block meta_description
    meta(name='description', content=(cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].seoDescription) || t('they_them.meta_description'))

block canonical
    link(rel='canonical', href=canonicalBase + localePrefix + 'they-them.html')

block og_title
    meta(property='og:title', content=(cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].seoTitle) || t('they_them.title'))
block og_description
    meta(property='og:description', content=(cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].seoDescription) || t('they_them.meta_description'))
block og_image
    meta(property='og:image', content=(cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].ogImage && cmsData.categoryPagesBySlug['they-them'].ogImage.match(/^https?:\/\//) ? cmsData.categoryPagesBySlug['they-them'].ogImage : canonicalBase + ((cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them'] && cmsData.categoryPagesBySlug['they-them'].ogImage) || 'assets/img/portfolio/theythem.png')))
block og_url
    meta(property='og:url', content=canonicalBase + localePrefix + 'they-them.html')

block content
    - var category = (cmsData.categoryPagesBySlug && cmsData.categoryPagesBySlug['they-them']) || null
    - var gallery = (category && category.gallery) || []
    - var shopUrl = (category && category.shopUrl) || 'https://shop.oioijewellery.it/collections/they-them'
    - var shopHandle = (category && category.shopCollectionHandle) || 'they-them'
    // Masthead
    header.masthead(style='padding-bottom: 3rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    img.mb-4.masthead-logotype(src=basePath + 'assets/img/logos/oioi_logotype_black.svg', alt='OIOI')
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.fw-medium.my-0(style='font-size: 1.4rem;')= (category && category.displayTitle) || 'THEY THEM'
                        span.decorative-icon.ms-2 ✴︎🜃
                    p.mt-3= (category && category.subtitle) || t('they_them.subtitle')
                    hr.divider

    // Collection Gallery
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.shop-cta-row.justify-content-center
                .col-12.text-center
                    a.shop-collection-link.shop-cta(href=shopUrl, data-collection=shopHandle)= t('they_them.shop_now')
            .row.g-4.justify-content-center
                each image, idx in gallery
                    .col-lg-4.col-md-6
                        a.shop-collection-link(href=shopUrl, data-collection=shopHandle)
                            img.img-fluid.portfolio-card-img(src=(image.url && image.url.match(/^https?:\/\//) ? image.url : basePath + image.url), alt=image.alt || ((category && category.displayTitle) || 'THEY THEM'), loading=(idx > 0 ? 'lazy' : null))

    // Description and Contact
    section#contact.page-section(style='padding-top: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-start
                .col-lg-6
                    p
                        strong= (category && category.descriptionOpening) || t('they_them.description_opening')
                        br
                        br
                        each p_text, idx in ((category && category.descriptionParagraphs) || i18n.they_them.description)
                            if idx > 0
                                br
                            = p_text
                        each closingLine in ((category && category.descriptionClosing) || [t('they_them.description_closing_1'), t('they_them.description_closing_2'), t('they_them.description_closing_3')])
                            br
                            br
                            strong= closingLine
                .col-lg-6

                    // Netlify Forms
                    form#contactForm(name='contact-they-them', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                        // Netlify Forms hidden fields
                        input(type='hidden', name='form-name', value='contact-they-them')
                        input(type='hidden', name='collection', value='THEY THEM')
                        // Honeypot field
                        input(type='text', name='bot-field', class='d-none')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name')= t('form.full_name')
                            .invalid-feedback(data-sb-feedback='name:required')
                                = t('form.name_required')

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email')= t('form.email')
                            .invalid-feedback(data-sb-feedback='email:required')
                                = t('form.email_required')
                            .invalid-feedback(data-sb-feedback='email:email')
                                = t('form.email_invalid')

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890'
                            )
                            label(for='phone')= t('form.phone')

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                type='text',
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message')= t('form.message')
                            .invalid-feedback(data-sb-feedback='message:required')
                                = t('form.message_required')

                        // Submit Button
                        .d-grid
                            button#submitButton.btn-reset(type='submit')
                                +svg-entra-in-contatto(t('form.submit_cta'), '140px')
