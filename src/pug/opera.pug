extends layout.pug

block title
    title= t('opera.title')

block meta_description
    meta(name='description', content=t('opera.meta_description'))

block canonical
    link(rel='canonical', href=canonicalBase + localePrefix + 'opera.html')

block og_title
    meta(property='og:title', content=t('opera.title'))
block og_description
    meta(property='og:description', content=t('opera.meta_description'))
block og_image
    meta(property='og:image', content=canonicalBase + 'assets/img/portfolio/opera/fullsize/ring1.jpg')
block og_url
    meta(property='og:url', content=canonicalBase + localePrefix + 'opera.html')

block content
    // Masthead
    header.masthead(style='padding-bottom: 3rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    img.mb-4.masthead-logotype(src=basePath + 'assets/img/logos/oioi_logotype_black.svg', alt='OIOI')
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.my-0(style='font-size: 1.4rem;') OPERA
                        span.decorative-icon.ms-2 ✴︎🜃
                    p.mt-3= t('opera.subtitle')
                    hr.divider

    // Collection Gallery
    section.page-section(style='padding-top: 2rem; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.g-4.justify-content-center
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/ring1.jpg', alt='Opera Collection Image 1')
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/dfg_blu.jpg', alt='Opera Collection Image 2', loading='lazy')
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/dfg_red.jpg', alt='Opera Collection Image 3', loading='lazy')
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/dfg_green.jpg', alt='Opera Collection Image 4', loading='lazy')
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/ring2.jpg', alt='Opera Collection Image 5', loading='lazy')
                .col-lg-4.col-md-6
                    img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/opera/fullsize/anello_michele.png', alt='Opera Collection - Anello Michele', loading='lazy')

    // Description and Contact
    section#contact.page-section(style='padding-top: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-start
                .col-lg-6
                    each p_text in i18n.opera.description
                        p= p_text
                    p
                        strong= t('opera.description_closing')
                .col-lg-6

                    // Netlify Forms
                    form#contactForm(name='contact-opera', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                        // Netlify Forms hidden fields
                        input(type='hidden', name='form-name', value='contact-opera')
                        input(type='hidden', name='collection', value='Opera')
                        // Honeypot field
                        input(type='text', name='bot-field', class='d-none')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name')= t('form.full_name')
                            .invalid-feedback(data-sb-feedback='name:required')
                                = t('form.name_required')

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email')= t('form.email')
                            .invalid-feedback(data-sb-feedback='email:required')
                                = t('form.email_required')
                            .invalid-feedback(data-sb-feedback='email:email')
                                = t('form.email_invalid')

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890'
                            )
                            label(for='phone')= t('form.phone')

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                type='text',
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message')= t('form.message')
                            .invalid-feedback(data-sb-feedback='message:required')
                                = t('form.message_required')

                        // Submit Button
                        .d-grid
                            button#submitButton.btn-reset(type='submit')
                                +svg-entra-in-contatto(t('form.submit_cta'), '140px')
