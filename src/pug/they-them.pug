extends layout.pug

block title
    title= t('they_them.title')

block meta_description
    meta(name='description', content=t('they_them.meta_description'))

block canonical
    link(rel='canonical', href=canonicalBase + localePrefix + 'they-them.html')

block og_title
    meta(property='og:title', content=t('they_them.title'))
block og_description
    meta(property='og:description', content=t('they_them.meta_description'))
block og_image
    meta(property='og:image', content=canonicalBase + 'assets/img/portfolio/theythem.png')
block og_url
    meta(property='og:url', content=canonicalBase + localePrefix + 'they-them.html')

block content
    // Masthead
    header.masthead(style='padding-bottom: 3rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    img.mb-4.masthead-logotype(src=basePath + 'assets/img/logos/oioi_logotype_black.svg', alt='OIOI')
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.fw-medium.my-0(style='font-size: 1.4rem;') THEY THEM
                        span.decorative-icon.ms-2 ✴︎🜃
                    p.mt-3= t('they_them.subtitle')
                    hr.divider

    // Collection Gallery
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.shop-cta-row.justify-content-center
                .col-12.text-center
                    a.shop-collection-link.shop-cta(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')= t('they_them.shop_now')
            .row.g-4.justify-content-center
                .col-lg-4.col-md-6
                    a.shop-collection-link(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')
                        img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/they-them/01-collection.png', alt='THEY THEM - Collezione')
                .col-lg-4.col-md-6
                    a.shop-collection-link(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')
                        img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/they-them/02-rings-all.png', alt='THEY THEM - Anelli', loading='lazy')
                .col-lg-4.col-md-6
                    a.shop-collection-link(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')
                        img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/they-them/03-rings-double.png', alt='THEY THEM - Anelli doppi', loading='lazy')
                .col-lg-4.col-md-6
                    a.shop-collection-link(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')
                        img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/they-them/04-rings-stack.png', alt='THEY THEM - Anelli impilati', loading='lazy')
                .col-lg-4.col-md-6
                    a.shop-collection-link(href='https://shop.oioijewellery.it/collections/they-them', data-collection='they-them')
                        img.img-fluid.portfolio-card-img(src=basePath + 'assets/img/portfolio/they-them/05-earrings.png', alt='THEY THEM - Orecchini', loading='lazy')

    // Description and Contact
    section#contact.page-section(style='padding-top: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-start
                .col-lg-6
                    p
                        strong= t('they_them.description_opening')
                        br
                        br
                        each p_text, idx in i18n.they_them.description
                            if idx > 0
                                br
                            = p_text
                        br
                        br
                        strong= t('they_them.description_closing_1')
                        br
                        br
                        strong= t('they_them.description_closing_2')
                        br
                        br
                        strong= t('they_them.description_closing_3')
                .col-lg-6

                    // Netlify Forms
                    form#contactForm(name='contact-they-them', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                        // Netlify Forms hidden fields
                        input(type='hidden', name='form-name', value='contact-they-them')
                        input(type='hidden', name='collection', value='THEY THEM')
                        // Honeypot field
                        input(type='text', name='bot-field', class='d-none')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name')= t('form.full_name')
                            .invalid-feedback(data-sb-feedback='name:required')
                                = t('form.name_required')

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email')= t('form.email')
                            .invalid-feedback(data-sb-feedback='email:required')
                                = t('form.email_required')
                            .invalid-feedback(data-sb-feedback='email:email')
                                = t('form.email_invalid')

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890'
                            )
                            label(for='phone')= t('form.phone')

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                type='text',
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message')= t('form.message')
                            .invalid-feedback(data-sb-feedback='message:required')
                                = t('form.message_required')

                        // Submit Button
                        .d-grid
                            button#submitButton.btn-reset(type='submit')
                                +svg-entra-in-contatto(t('form.submit_cta'), '140px')
