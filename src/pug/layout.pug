include mixins/_svg_buttons.pug

- var canonicalBase = 'https://oioijewellery.it/'
- var localePrefix = (locale === 'it') ? 'it/' : ''
- var otherLocale = (locale === 'en') ? 'it' : 'en'
- var otherPath = (locale === 'en') ? 'it/' : '../'

doctype html
html(lang=i18n.meta.lang)

    head
        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')

        //- Language detection — inline to avoid flash
        script.
            (function(){
                var COOKIE='oioi_lang';
                var saved=localStorage.getItem(COOKIE);
                if(!saved){
                    var m=document.cookie.match(new RegExp('(?:^|;\\s*)'+COOKIE+'=([^;]+)'));
                    saved=m?m[1]:null;
                }
                if(!saved){
                    var bl=(navigator.language||'').substring(0,2);
                    saved=(bl==='it')?'it':'en';
                }
                var onIt=/^\/it(\/|$)/.test(window.location.pathname);
                var needsIt=(saved==='it');
                if(window.location.hostname==='localhost'||window.location.hostname==='127.0.0.1')return;
                if(needsIt&&!onIt){
                    window.location.replace('/it'+window.location.pathname+window.location.search);
                }else if(!needsIt&&onIt){
                    var p=window.location.pathname.replace(/^\/it/,'')||'/';
                    window.location.replace(p+window.location.search);
                }
            })();
        
        // Google Consent Mode v2 - Initialize before GTM
        script.
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            
            gtag('consent', 'default', {
                'analytics_storage': 'denied',
                'ad_storage': 'denied',
                'ad_user_data': 'denied',
                'ad_personalization': 'denied',
                'wait_for_update': 500
            });
        
        // Google Tag Manager
        script.
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-W759WSVM');

        block meta_description
            meta(name='description', content="OIOI Jewellery — Florence-born artisanal jewellery.")
        
        meta(name='author', content='OIOI Jewellery')

        // Open Graph meta tags
        block og_title
            meta(property='og:title', content='OIOI Jewellery')
        block og_description
            meta(property='og:description', content="Florence-born artisanal jewellery.")
        block og_image
            meta(property='og:image', content='https://oioijewellery.it/assets/img/about/about_hero.png')
        block og_url
            meta(property='og:url', content=canonicalBase + localePrefix)
        meta(property='og:type', content='website')
        meta(property='og:site_name', content='OIOI Jewellery')
        meta(property='og:locale', content=i18n.meta.og_locale)

        // Twitter Card
        meta(name='twitter:card', content='summary_large_image')

        block title
            title OIOI Jewellery
        
        block canonical
            link(rel='canonical', href=canonicalBase + localePrefix)

        //- hreflang alternates
        block hreflang
            link(rel='alternate', hreflang='en', href=canonicalBase + currentPage)
            link(rel='alternate', hreflang='it', href=canonicalBase + 'it/' + currentPage)
            link(rel='alternate', hreflang='x-default', href=canonicalBase + currentPage)

        // Schema.org Organization Markup
        script(type='application/ld+json').
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "OIOI Jewellery",
                "url": "https://oioijewellery.it",
                "logo": "https://oioijewellery.it/assets/img/logos/oioi_black.svg",
                "description": "Artisanal jewellery handcrafted in Florence.",
                "sameAs": [
                    "https://www.instagram.com/oioijewellery/",
                    "https://www.facebook.com/oioijewellery"
                ]
            }

        // Favicon
        link(rel='icon', type='image/svg+xml', href=basePath + 'assets/favicon.svg')
        link(rel='alternate icon', type='image/x-icon', href=basePath + 'assets/favicon.ico')

        // Bootstrap Icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts
        link(rel='preconnect', href='https://fonts.googleapis.com')
        link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
        link(href='https://fonts.googleapis.com/css2?family=Allura&family=Poppins:wght@400;500;700&display=swap', rel='stylesheet')

        // SimpleLightbox plugin CSS
        link(href='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css', rel='stylesheet')

        // Core theme CSS (includes Bootstrap)
        link(href=basePath + 'css/styles.css', rel='stylesheet')

    body#page-top
        // Google Tag Manager (noscript)
        noscript
            iframe(src='https://www.googletagmanager.com/ns.html?id=GTM-W759WSVM', height='0', width='0', style='display:none;visibility:hidden')

        // Navigation
        nav#mainNav.navbar.navbar-expand-lg.navbar-light.fixed-top.py-3
            .container.px-4.px-lg-5
                a.navbar-brand(href='index.html#page-top')
                    +svg-logo-oioi('90px')
                button.navbar-toggler.navbar-toggler-right(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    span.navbar-toggler-icon
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.ms-auto.my-2.my-lg-0
                        li.nav-item
                            a.nav-link(href='index.html')= t('nav.home')
                        li.nav-item
                            a.nav-link(href='about.html')= t('nav.about')
                        li.nav-item.nav-item--cart#cartNavItem
                            a.nav-link#nav-shop-link(href='shop-coming-soon.html')
                                = t('nav.shop') + ' '
                                span.nav-cart-badge.d-none#cartBadge 0
                            .cart-preview#cartPreview(aria-hidden='true')
                                .cart-preview__empty#cartPreviewEmpty
                                    p= t('cart_preview.empty')
                                    a.cart-preview__cta(href='https://shop.oioijewellery.it/collections/all', data-cross-domain)= t('cart_preview.discover')
                                .cart-preview__body.d-none#cartPreviewBody
                                    ul.cart-preview__items#cartPreviewItems
                                    .cart-preview__footer
                                        .cart-preview__total
                                            span= t('cart_preview.total')
                                            span#cartPreviewTotal
                                        a.cart-preview__cta#cartPreviewCheckout(href='https://shop.oioijewellery.it/cart', data-cross-domain)= t('cart_preview.go_to_cart')
                        li.nav-item
                            a.nav-link(href='index.html#contact')= t('nav.enquiry')
                        li.nav-item
                            a.nav-link(href='https://www.instagram.com/oioijewellery/' target='_blank' rel='noopener')= t('nav.instagram')
                        li.nav-item.ms-lg-2
                            a.nav-link.header-locale-switch(
                                href=otherPath + currentPage,
                                data-locale=otherLocale,
                                onclick="document.cookie='oioi_lang=" + otherLocale + ";path=/;domain=.oioijewellery.it;max-age=31536000;SameSite=Lax;Secure';localStorage.setItem('oioi_lang','" + otherLocale + "')"
                            )= otherLocale.toUpperCase()

        block content

        // Cookie Banner
        #cookieBanner.cookie-banner(role='dialog', aria-label='Cookie consent', aria-hidden='true')
            .cookie-banner-content
                .cookie-banner-text
                    p.mb-0
                        = t('cookie_banner.text')
                        a(href='cookie-policy.html')= t('cookie_banner.more_info')
                .cookie-banner-actions
                    button#cookieAccept.btn.btn-sm.btn-primary(type='button')= t('cookie_banner.accept')
                    a.btn.btn-sm.btn-outline-secondary(href='cookie-policy.html')= t('cookie_banner.manage')

        // Footer
        footer.py-5
            .container.px-4.px-lg-5
                .small.text-center.text-muted
                    = t('footer.copyright')
                    br
                    = t('footer.vat')
                    br
                    .mt-2.mb-2
                        a.me-2(href='cookie-policy.html')= t('footer.cookie_policy')
                        span.me-2 |
                        a.me-2(href='#', onclick='window.showCookiePreferences(); return false;')= t('footer.manage_cookies')
                    .mt-2
                        a.me-3(href='https://www.instagram.com/oioijewellery/' target='_blank' rel='noopener', aria-label='Instagram')
                            i.bi.bi-instagram(style='font-size: 1.2rem;')
                        a.me-3(href='https://wa.me/393475443897' target='_blank' rel='noopener', aria-label='WhatsApp')
                            i.bi.bi-whatsapp(style='font-size: 1.2rem;')
                        a(href='https://www.facebook.com/oioijewellery' target='_blank' rel='noopener', aria-label='Facebook')
                            i.bi.bi-facebook(style='font-size: 1.2rem;')

        block scripts
            // Bootstrap core JS
            script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js')

            // SimpleLightbox plugin JS
            script(src='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js')

            // Core theme JS
            script(src=basePath + 'js/scripts.js')
            
            // Cookie Banner JS
            script(src=basePath + 'js/cookie-banner.js')

            // Cart — Storefront API
            script(src=basePath + 'js/oioi-cart.js')
            script.
                window.oioiCart = new OioiCart({
                    token: '8e43de797137357bb233ec0a6befa723',
                    domain: 'oioi-shop-dev-basic.myshopify.com'
                });
                window.oioiCart.onChange(function (cart) {
                    window.oioiCart.patchCrossDomainLinks();
                    updateCartBadge(cart);
                });
                window.oioiCart.init().then(function (cart) {
                    window.oioiCart.patchCrossDomainLinks();
                    updateCartBadge(cart);
                });
                function updateCartBadge(cart) {
                    if (!cart) return;
                    var count = cart.totalQuantity || 0;
                    document.querySelectorAll('.nav-cart-badge').forEach(function(b) {
                        b.textContent = count;
                        if (count > 0) { b.classList.remove('d-none'); }
                        else { b.classList.add('d-none'); }
                    });
                }
            script(src=basePath + 'js/oioi-cart-preview.js')
