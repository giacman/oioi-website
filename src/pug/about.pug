extends layout.pug

block title
    title= t('about.title')

block meta_description
    meta(name='description', content=t('about.meta_description'))

block canonical
    link(rel='canonical', href=canonicalBase + localePrefix + 'about.html')

block og_title
    meta(property='og:title', content=t('about.title'))
block og_description
    meta(property='og:description', content=t('about.meta_description'))
block og_url
    meta(property='og:url', content=canonicalBase + localePrefix + 'about.html')

block content
    // Masthead (centered, consistent with other pages)
    header.masthead(style='padding-bottom: 1rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    img.mb-4.masthead-logotype(src=basePath + 'assets/img/logos/oioi_logotype_black.svg', alt='OIOI')
                    .d-flex.justify-content-center.align-items-center.mb-3
                        span.decorative-icon.me-2 🜃✴︎
                        h1.my-0(style='font-size: 1.4rem;')= t('about.heading')
                        span.decorative-icon.ms-2 ✴︎🜃
                    hr.divider

    // Hero — two-column layout (text left, image right)
    section.page-section(style='padding-top: 1rem; padding-bottom: 1rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center
                .col-lg-6.mb-4.mb-lg-0
                    each p_text in i18n.about.intro
                        p= p_text
                    p.mt-4= t('about.intro_closing')
                .col-lg-6
                    img.img-fluid.w-100(src=basePath + 'assets/img/about/about_hero.png', alt='OIOI Jewellery')

    // Content
    section.page-section(style='padding-top: 2rem; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .mb-5
                h2.mb-4(style='font-size: 1rem;')= t('about.la_porta.title')
                each p_text in i18n.about.la_porta.paragraphs
                    p= p_text

    // IL METODO — two-column layout (text left, image right)
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center
                .col-lg-6.mb-4.mb-lg-0
                    h2.mb-4(style='font-size: 1rem;')= t('about.il_metodo.title')
                    each p_text in i18n.about.il_metodo.paragraphs
                        p= p_text
                .col-lg-6
                    img.img-fluid.w-100(src=basePath + 'assets/img/about/metodo_hero.png', alt='OIOI - Il Metodo')

    // Content continued
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .mb-5
                h2.mb-4(style='font-size: 1rem;')= t('about.estetica.title')
                each p_text in i18n.about.estetica.paragraphs
                    p= p_text

    // ATTITUDINE — two-column layout (text left, image right)
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.align-items-center
                .col-lg-6.mb-4.mb-lg-0
                    h2.mb-4(style='font-size: 1rem;')= t('about.attitudine.title')
                    each p_text in i18n.about.attitudine.paragraphs
                        p= p_text
                .col-lg-6
                    img.img-fluid.w-100(src=basePath + 'assets/img/about/attitudine_hero.png', alt='OIOI - Attitudine')

    // Content continued
    section.page-section(style='padding-top: 0; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .mb-5
                h2.mb-4(style='font-size: 1rem;')= t('about.per_chi.title')
                each p_text in i18n.about.per_chi.paragraphs
                    p= p_text

            .mb-5
                h2.mb-4(style='font-size: 1rem;')= t('about.chi_la_fa.title')
                each p_text in i18n.about.chi_la_fa.paragraphs
                    p= p_text

            .mb-5

    // Contact
    section#contact.page-section(style='padding-top: 0rem; padding-bottom: 2rem;')
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-8.col-xl-6.text-center
                    p.mb-2= t('about.contact_intro')
                    h2.font-calligraphy= t('about.contact_calligraphy')
                    hr.divider
            .row.gx-4.gx-lg-5.justify-content-center.mb-5
                .col-lg-6

                    // Netlify Forms
                    form#contactForm(name='contact', method='POST', data-netlify='true', netlify-honeypot='bot-field', action=(locale === 'en' ? '/success.html' : '/it/success.html'))

                        // Netlify Forms hidden fields
                        input(type='hidden', name='form-name', value='contact')
                        // Honeypot field
                        input(type='text', name='bot-field', class='d-none')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name')= t('form.full_name')
                            .invalid-feedback(data-sb-feedback='name:required')
                                = t('form.name_required')

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email')= t('form.email')
                            .invalid-feedback(data-sb-feedback='email:required')
                                = t('form.email_required')
                            .invalid-feedback(data-sb-feedback='email:email')
                                = t('form.email_invalid')

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890'
                            )
                            label(for='phone')= t('form.phone')

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                type='text',
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message')= t('form.message')
                            .invalid-feedback(data-sb-feedback='message:required')
                                = t('form.message_required')

                        // Submit Button
                        .d-grid
                            button#submitButton.btn-reset(type='submit')
                                +svg-entra-in-contatto(t('form.submit_cta'), '140px')
